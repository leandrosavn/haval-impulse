{
  "name": "cluster-air-ui",
  "private": true,
  "version": "0.0.4",
  "browserslist": [
    "last 3 versions",
    "not dead",
    "chrome 80",
    "android >= 9"
  ],
  "scripts": {
    "dev": "parcel index.html",
    "dev-controls": "npm run dev",
    "clear": "rimraf dist .parcel-cache",
    "build": "bun run clear && parcel build index.html --dist-dir dist --public-url ./ --no-source-maps && node inline.js",
    "prerelease": "bun run build"
  },
  "devDependencies": {
    "baseline-browser-mapping": "^2.10.11",
    "bun": "^1.3.0",
    "parcel": "^2.16.4",
    "rimraf": "^6.0.1"
  },
  "dependencies": {
    "chartjs-adapter-date-fns": "^3.0.0",
    "chartjs-plugin-streaming": "^2.0.0",
    "date-fns": "^4.1.0"
  }
}
